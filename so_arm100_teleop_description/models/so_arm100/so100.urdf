<?xml version='1.0' encoding='utf-8'?>
<robot name="so_arm100">
  
  <link name="world"/>
  <joint name="world_fixed" type="fixed">
    <parent link="world"/>
    <child link="base"/>
    <origin xyz="0 0 0" rpy="0 0 1.5708"/>
  </joint>

  <material name="3d_printed"><color rgba="1.0 0.82 0.12 1.0"/></material>
  <material name="sts3215"><color rgba="0.1 0.1 0.1 1.0"/></material>

  <link name="base">
    <inertial>
      <mass value="1.0"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
    </inertial>
    <visual>
      <geometry><mesh filename="package://so_arm100_teleop_description/models/so_arm100/assets/Base.stl"/></geometry>
      <material name="3d_printed"/>
    </visual>
    <collision>
      <geometry><mesh filename="package://so_arm100_teleop_description/models/so_arm100/assets/Base.stl"/></geometry>
    </collision>
  </link>

  <link name="shoulder">
    <inertial>
      <mass value="0.119226"/>
      <origin xyz="-9.07886e-05 0.0590972 0.031089" rpy="0 0 0"/>
      <inertia ixx="5.94278e-05" ixy="0" ixz="0" iyy="5.89975e-05" iyz="0" izz="3.13712e-05"/>
    </inertial>
    <visual>
      <geometry><mesh filename="package://so_arm100_teleop_description/models/so_arm100/assets/Rotation_Pitch.stl"/></geometry>
      <material name="3d_printed"/>
    </visual>
    <collision>
      <geometry><mesh filename="package://so_arm100_teleop_description/models/so_arm100/assets/Rotation_Pitch.stl"/></geometry>
    </collision>
  </link>

  <link name="upper_arm">
    <inertial>
      <mass value="0.162409"/>
      <origin xyz="-1.72052e-05 0.0701802 0.00310545" rpy="0 0 0"/>
      <inertia ixx="0.000213312" ixy="0" ixz="0" iyy="0.000167164" iyz="0" izz="7.01522e-05"/>
    </inertial>
    <visual>
      <geometry><mesh filename="package://so_arm100_teleop_description/models/so_arm100/assets/Upper_Arm.stl"/></geometry>
      <material name="3d_printed"/>
    </visual>
    <collision>
      <geometry><mesh filename="package://so_arm100_teleop_description/models/so_arm100/assets/Upper_Arm.stl"/></geometry>
    </collision>
  </link>

  <link name="lower_arm">
    <inertial>
      <mass value="0.147968"/>
      <origin xyz="-0.00339604 0.00137796 0.0768007" rpy="0 0 0"/>
      <inertia ixx="0.000138803" ixy="0" ixz="0" iyy="0.000107748" iyz="0" izz="4.84242e-05"/>
    </inertial>
    <visual>
      <geometry><mesh filename="package://so_arm100_teleop_description/models/so_arm100/assets/Lower_Arm.stl"/></geometry>
      <material name="3d_printed"/>
    </visual>
    <collision>
      <geometry><mesh filename="package://so_arm100_teleop_description/models/so_arm100/assets/Lower_Arm.stl"/></geometry>
    </collision>
  </link>

  <link name="wrist">
    <inertial>
      <mass value="0.0661321"/>
      <origin xyz="-0.00852653 -0.0352279 -2.34622e-05" rpy="0 0 0"/>
      <inertia ixx="3.45403e-05" ixy="0" ixz="0" iyy="2.39041e-05" iyz="0" izz="1.94704e-05"/>
    </inertial>
    <visual>
      <geometry><mesh filename="package://so_arm100_teleop_description/models/so_arm100/assets/Wrist_Pitch_Roll.stl"/></geometry>
      <material name="3d_printed"/>
    </visual>
    <collision>
      <geometry><mesh filename="package://so_arm100_teleop_description/models/so_arm100/assets/Wrist_Pitch_Roll.stl"/></geometry>
    </collision>
  </link>

  <link name="gripper">
    <inertial>
      <mass value="0.1"/> <origin xyz="0.0055 -0.0280 0.0004" rpy="0 0 0"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
    <visual>
      <geometry><mesh filename="package://so_arm100_teleop_description/models/so_arm100/assets/Fixed_Jaw.stl"/></geometry>
      <material name="3d_printed"/>
    </visual>
    <collision>
      <geometry><mesh filename="package://so_arm100_teleop_description/models/so_arm100/assets/Fixed_Jaw.stl"/></geometry>
    </collision>
  </link>

  <link name="jaw">
    <inertial>
      <mass value="0.1"/> <origin xyz="-0.0016 -0.0303 0.0004" rpy="0 0 0"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
    <visual>
      <geometry><mesh filename="package://so_arm100_teleop_description/models/so_arm100/assets/Moving_Jaw.stl"/></geometry>
      <material name="3d_printed"/>
    </visual>
    <collision>
      <geometry><mesh filename="package://so_arm100_teleop_description/models/so_arm100/assets/Moving_Jaw.stl"/></geometry>
    </collision>
  </link>

  <joint name="shoulder_pan" type="revolute">
    <parent link="base"/><child link="shoulder"/>
    <origin xyz="0 -0.0452 0.0165" rpy="1.57079 0 0"/>
    <axis xyz="0 1 0"/><limit lower="-2" upper="2" effort="35" velocity="5"/>
    <dynamics damping="0.1" friction="0.05"/>
  </joint>

  <joint name="shoulder_lift" type="revolute">
    <parent link="shoulder"/><child link="upper_arm"/>
    <origin xyz="0 0.1025 0.0306" rpy="-1.8 0 0"/>
    <axis xyz="1 0 0"/><limit lower="0" upper="3.5" effort="35" velocity="5"/>
    <dynamics damping="0.1" friction="0.05"/>
  </joint>

  <joint name="elbow_flex" type="revolute">
    <parent link="upper_arm"/><child link="lower_arm"/>
    <origin xyz="0 0.11257 0.028" rpy="1.57079 0 0"/>
    <axis xyz="1 0 0"/><limit lower="-3.14158" upper="0" effort="35" velocity="5"/>
    <dynamics damping="0.1" friction="0.05"/>
  </joint>

  <joint name="wrist_flex" type="revolute">
    <parent link="lower_arm"/><child link="wrist"/>
    <origin xyz="0 0.0052 0.1349" rpy="-1 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-2.5" upper="1.2" effort="35" velocity="5"/>
    <dynamics damping="1.5" friction="0.5"/> 
  </joint>

  <joint name="wrist_roll" type="revolute">
    <parent link="wrist"/><child link="gripper"/>
    <origin xyz="0 -0.0601 0" rpy="0 1.57079 0"/>
    <axis xyz="0 1 0"/><limit lower="-3.14158" upper="3.14158" effort="35" velocity="5"/>
    <dynamics damping="0.1" friction="0.1"/>
  </joint>

  <joint name="gripper_joint" type="revolute">
    <parent link="gripper"/><child link="jaw"/>
    <origin xyz="-0.0202 -0.0244 0" rpy="0 3.14158 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.2" upper="2.0" effort="10" velocity="3"/>
    <dynamics damping="1.0" friction="0.8"/> 
  </joint>

  <link name="camera_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.02 0.05 0.02"/>
      </geometry>
      <material name="sts3215"/>
    </visual>
  </link>

  <joint name="camera_joint" type="fixed">
    <parent link="gripper"/>
    <child link="camera_link"/>
    <origin xyz="0 -0.05 0.03" rpy="0 0 -1.5708"/> 
  </joint>

  <link name="camera_link_optical"/>
  <joint name="camera_optical_joint" type="fixed">
    <origin xyz="0 0 0" rpy="-1.5708 0 -1.5708"/>
    <parent link="camera_link"/>
    <child link="camera_link_optical"/>
  </joint>

  <gazebo>
    <plugin
      filename="gz-sim-joint-state-publisher-system"
      name="gz::sim::systems::JointStatePublisher"/>

    <plugin filename="ignition-gazebo-joint-position-controller-system" name="ignition::gazebo::systems::JointPositionController">
      <joint_name>shoulder_pan</joint_name>
      <p_gain>40.0</p_gain>
      <i_gain>0.01</i_gain>
      <d_gain>2.0</d_gain>
    </plugin>

    <plugin filename="ignition-gazebo-joint-position-controller-system" name="ignition::gazebo::systems::JointPositionController">
      <joint_name>shoulder_lift</joint_name>
      <p_gain>80.0</p_gain>
      <i_gain>0.0</i_gain>
      <d_gain>5.0</d_gain>
    </plugin>

    <plugin filename="ignition-gazebo-joint-position-controller-system" name="ignition::gazebo::systems::JointPositionController">
      <joint_name>elbow_flex</joint_name>
      <p_gain>40.0</p_gain>
      <i_gain>0.0</i_gain>
      <d_gain>2.0</d_gain>
    </plugin>

    <plugin filename="ignition-gazebo-joint-position-controller-system" name="ignition::gazebo::systems::JointPositionController">
      <joint_name>wrist_flex</joint_name>
      <p_gain>20.0</p_gain>
      <i_gain>0.0</i_gain>
      <d_gain>1.0</d_gain> <i_max>1.0</i_max>
    </plugin>

    <plugin filename="ignition-gazebo-joint-position-controller-system" name="ignition::gazebo::systems::JointPositionController">
      <joint_name>wrist_roll</joint_name>
      <p_gain>50.0</p_gain>
      <i_gain>0.1</i_gain>
      <d_gain>1.0</d_gain>
    </plugin>

    <plugin filename="ignition-gazebo-joint-position-controller-system" name="ignition::gazebo::systems::JointPositionController">
      <joint_name>gripper_joint</joint_name>
      <p_gain>100.0</p_gain>
      <i_gain>20.0</i_gain> <d_gain>0.5</d_gain>
      <i_max>2.0</i_max>
    </plugin>
  </gazebo>

  <gazebo reference="camera_link">
    <sensor name="hand_camera" type="camera">
      <pose>0 0 0 0 0 0</pose>
      <visualize>true</visualize>
      <update_rate>30</update_rate>

      <topic>arm_camera/image_raw</topic>
      <camera_info_topic>arm_camera/camera_info</camera_info_topic>

      <camera>
        <horizontal_fov>1.089</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.05</near>
          <far>8.0</far>
        </clip>
      </camera>
    </sensor>
  </gazebo>
  
</robot>